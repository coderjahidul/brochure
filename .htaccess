<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /brochure/

    # Serve existing files directly (PDFs, assets, API scripts)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Redirect old category URLs: /category/brother/ -> /brother/
    RewriteRule ^category/([a-z0-9-]+)/?$ $1/ [L,R=301]

    # Redirect old search URLs to homepage
    RewriteRule ^search/?$ index.php [L,R=301,QSA]

    # Static pages
    RewriteRule ^download-copier-brochures/?$ index.php?page=download-copier-brochures [L,QSA]
    RewriteRule ^other-brochures/?$ index.php?page=other-brochures [L,QSA]
    RewriteRule ^about/?$ index.php?page=about [L,QSA]
    RewriteRule ^contact/?$ index.php?page=contact [L,QSA]

    # Brand pages: /brother/, /canon/, etc.
    RewriteRule ^([a-z0-9-]+)/?$ index.php?page=category&slug=$1 [L,QSA]

    # Homepage
    RewriteRule ^$ index.php [L]
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType application/pdf "access plus 1 week"
</IfModule>
